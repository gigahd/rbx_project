{
  "name": "{{project_name}}",
  "globIgnorePaths": ["**/*.spec.luau", "**/*.story.luau", "**/*.storybook.luau"],
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Shared": {
        "$path": "src/shared"
      },
      "Packages": {
        "$path": {"optional": "Packages"}
      },
      "DevPackages": {
        "$path": {"optional": "DevPackages"}
      }
      ,
      "Assets": {
        "$path": "Assets/Shared"
      },
      "Network": {
        "$path": { "optional": "Network/Client"}
      }
    },

    "ServerScriptService": {
      "Server": {
        "$path": "src/server"
      },
      "ServerPackages": {
        "$path": {"optional": "ServerPackages"}
      },
      "Network": {
        "$path": { "optional": "Network/Server" }
      }
    },
    "ServerStorage": {
      "Assets": {
        "$path": "Assets/Server"
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "Client": {
          "$path": "src/client"
        }
      }
    }
  }
}
